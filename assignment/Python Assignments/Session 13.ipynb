   "source": [
    "1.# Write a recursive function in Python called reverse_string(s) that takes a string and returns it reversed (e.g., 'hello' becomes 'olleh').\n",
    "def reverse(s):\n",
    "\n",
    "    if len(s)==0:\n",
    "        return \"\"\n",
    "\n",
    "    return reverse(s[1:])+s[0]\n",
    "\n",
    "print(reverse(\"Python\"))"
   ]
  }
